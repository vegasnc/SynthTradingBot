{
  "manifest_version": 3,
  "name": "DemoBot Trading Dashboard",
  "version": "1.0.0",
  "description": "Trading bot dashboard and controls for Synth-powered crypto and equity trading",
  "permissions": ["storage"],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*",
    "ws://localhost:8000/*",
    "ws://127.0.0.1:8000/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    }
  },
  "options_page": "options/options.html",
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "icons": {
    "16": "assets/icons/icon16.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "web_accessible_resources": [
    { "resources": ["dashboard/*", "options/*", "lib/*"], "matches": ["<all_urls>"] }
  ]
}
